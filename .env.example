# Copia este archivo a .env y rellena los valores reales.
# .env nunca debe commitearse al repositorio.

# Obligatorio: clave de TomTom Routing API (https://developer.tomtom.com/)
VCENTENARIO_TOMTOM_API_KEY=

# Opcional: token Bearer para POST /api/refresh
# VCENTENARIO_REFRESH_TOKEN=cambia-este-token
# VCENTENARIO_ENABLE_REFRESH_ENDPOINT=true

# Opcional: alertas por email
# VCENTENARIO_ALERT_EMAIL_ENABLED=true
# VCENTENARIO_ALERT_EMAIL_SMTP_SERVER=smtp.gmail.com
# VCENTENARIO_ALERT_EMAIL_USER=
# VCENTENARIO_ALERT_EMAIL_PASSWORD=
# VCENTENARIO_ALERT_EMAIL_RECIPIENTS=destino@example.com
